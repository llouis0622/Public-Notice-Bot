# Busan city notice board base URL
BUSAN_NOTICE_URL=https://www.busan.go.kr/nbmain

# Gmail credentials (use an App Password, not your account password)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Comma-separated recipient email addresses
NOTIFY_EMAIL=recipient@example.com

# Optional: webhook URL to POST new notices as JSON
WEBHOOK_URL=

# SQLAlchemy database URL (PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/public_notice_bot

# How often to check for new notices (minutes)
CHECK_INTERVAL_MINUTES=30

# Comma-separated notice categories to monitor (leave empty for all)
# Options: 입찰공고,채용공고,행정예고
NOTICE_CATEGORIES=
